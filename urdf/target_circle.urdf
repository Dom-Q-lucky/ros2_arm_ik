<?xml version="1.0"?>
<robot name="target_platform">
  <link name="platform_link">
    <visual>
      <geometry>
        <box size="0.4 0.4 0.05"/> </geometry>
    </visual>
    <collision>
      <geometry>
        <box size="0.4 0.4 0.05"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <gazebo reference="platform_link">
    <visual>
      <material>
        <ambient>0 1 0 1</ambient>   <diffuse>0 1 0 1</diffuse>
        <specular>0.1 0.1 0.1 1</specular>
      </material>
    </visual>
    <static>true</static>
  </gazebo>
</robot>