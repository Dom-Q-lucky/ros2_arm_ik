<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="simple_base">

  <material name="grey"><color rgba="0.3 0.3 0.3 1"/></material>

  <link name="base_footprint"/>
  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.07" rpy="0 0 0"/> 
  </joint>

  <link name="base_link">
    <visual>
      <geometry><box size="0.7 0.5 0.08"/></geometry> <material name="grey"/>
    </visual>
    <collision>
      <geometry><box size="0.7 0.5 0.08"/></geometry>
    </collision>
    <inertial>
      <mass value="80.0"/> 
      <origin xyz="0 0 -0.1" rpy="0 0 0"/>
      <inertia ixx="3.0" ixy="0" ixz="0" iyy="4.0" iyz="0" izz="5.0"/>
    </inertial>
  </link>

  <xacro:macro name="wheel" params="prefix x_reflect y_reflect">
    <link name="${prefix}_wheel">
      <visual>
        <geometry><cylinder radius="0.05" length="0.04"/></geometry>
        <material name="grey"/>
      </visual>
      <collision>
        <geometry><cylinder radius="0.05" length="0.04"/></geometry>
      </collision>
      <inertial>
        <mass value="2.0"/>
        <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.002"/>
      </inertial>
    </link>

    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${prefix}_wheel"/>
      <origin xyz="${x_reflect*0.25} ${y_reflect*0.28} -0.02" rpy="-1.5708 0 0"/>
      <axis xyz="0 0 1"/>
    </joint>
  </xacro:macro>

  <xacro:wheel prefix="fl" x_reflect="1"  y_reflect="1" />
  <xacro:wheel prefix="fr" x_reflect="1"  y_reflect="-1" />
  <xacro:wheel prefix="rl" x_reflect="-1" y_reflect="1" />
  <xacro:wheel prefix="rr" x_reflect="-1" y_reflect="-1" />
  
  <link name="base_camera_link">
    <visual>
      <geometry><box size="0.05 0.05 0.05"/></geometry>
      <material name="grey"/>
    </visual>
  </link>

  <joint name="base_camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="base_camera_link"/>
    <origin xyz="0.35 0 0.08" rpy="0 0 0"/> </joint>

  <gazebo reference="base_camera_link">
    <sensor name="base_camera" type="camera">
      <camera>
        <horizontal_fov>1.089</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>8.0</far>
        </clip>
      </camera>
      <always_on>1</always_on>
      <update_rate>30</update_rate>
      <visualize>true</visualize> <topic>/base_camera/image_raw</topic> <gz_frame_id>base_camera_link</gz_frame_id>
    </sensor>
  </gazebo>
  <gazebo>
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>fl_wheel_joint</left_joint>
      <left_joint>rl_wheel_joint</left_joint>
      <right_joint>fr_wheel_joint</right_joint>
      <right_joint>rr_wheel_joint</right_joint>
      <wheel_separation>0.56</wheel_separation>
      <wheel_diameter>0.1</wheel_diameter> <max_wheel_torque>2000</max_wheel_torque> 
      <max_linear_acceleration>0.5</max_linear_acceleration>
      <topic>/model/mobile_panda/cmd_vel</topic>
      <odom_topic>/model/mobile_panda/odometry</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
    </plugin>
  </gazebo>
</robot>