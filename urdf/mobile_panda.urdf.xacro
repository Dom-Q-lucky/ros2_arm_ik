<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="mobile_panda">

  <xacro:include filename="simple_base.xacro" />

  <xacro:include filename="panda_fixed_only.urdf" />

  <joint name="base_to_arm" type="fixed">
    <parent link="base_link" />
    <child link="panda_link0" />
    <origin xyz="0.2 0 0.1" rpy="0 0 0" />
  </joint>

</robot>